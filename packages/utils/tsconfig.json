{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // ========== 输出配置 ==========
    "baseUrl": ".",
    "rootDir": "./src",
    "outDir": "./dist",
    "declarationDir": "./dist/types",

    // ========== 模块系统 ==========
    "module": "ESNext",

    // ========== 路径别名 ==========
    "paths": {
      "@/*": ["./src/*"],
      "@small-brother/utils": ["./src"]
    },

    // ========== 类型定义 ==========
    "types": ["node"]
  },
  "include": ["src/**/*", "**/*.d.ts"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts", "vitest.config.ts"]
}
